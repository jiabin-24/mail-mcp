# Mail MCP runtime settings
MCP_HOST=127.0.0.1
MCP_PORT=80
MCP_PATH=/mcp

# Microsoft Graph
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
OUTLOOK_ACCESS_TOKEN=
DELEGATED_TOKEN_LOG_MODE=masked
DELEGATED_TOKEN_CACHE_TTL_SECONDS=300

# Azure Storage Table (scheduled send queue)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_TABLE_NAME=EmailSendQueue

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Expose AGENTS.md file for MCP service discovery
MCP_EXPOSE_AGENTS_MD=false

# Dynamic OAuth Discovery (OAuth 2.0 + DCR)
MCP_OAUTH_DYNAMIC_DISCOVERY_ENABLED=true
MCP_PUBLIC_BASE_URL=
MCP_OAUTH_ISSUER_URL=
MCP_OAUTH_CALLBACK_URL=
MCP_OAUTH_SERVICE_DOCUMENTATION_URL=
MCP_OAUTH_TENANT_ID=
MCP_OAUTH_CLIENT_ID=
MCP_OAUTH_CLIENT_SECRET=
MCP_OAUTH_ENTRA_SCOPES=openid profile offline_access User.ReadBasic.All Mail.Read Mail.ReadWrite Mail.Send Calendars.Read Calendars.ReadWrite MailboxSettings.Read
